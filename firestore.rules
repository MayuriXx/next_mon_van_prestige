rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Collections publiques en lecture seule
    match /tarifs/{doc} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    match /faq/{doc} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    match /vehicules/{doc} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    match /contenus/{doc} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // Image metadata collections (Issue #23) — public read, admin write.
    // The public site reads these to display hero / vehicle / section images;
    // without public read the anonymous reads return permission-denied and the
    // UI falls back to static local images (and shows an error toast).
    match /images/{doc} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    match /vehicle_images/{doc} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    match /section_images/{doc} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // Homepage services & vehicles content (read by lib/firebase/contenu.ts).
    // Public read so admin-managed overrides are visible to visitors.
    match /services/{doc} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    match /vehicles/{doc} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // Réservations : création publique, lecture/modif admin uniquement
    match /reservations/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && isAdmin();
    }

    // Tout le reste : admin uniquement
    match /{document=**} {
      allow read, write: if request.auth != null && isAdmin();
    }

    function isAdmin() {
      return request.auth.token.email == 'martho.evan@gmail.com';
    }
  }
}
